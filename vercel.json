{
  "framework": null,
  "installCommand": "echo 'No install'",
  "buildCommand": "cd frontend && npm ci && npm run build && cd ../backend && npm ci",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs24.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
